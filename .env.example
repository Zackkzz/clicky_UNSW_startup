# Copy to ".env". Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.

# --- Cloud Supabase (Settings → API) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Auth (Supabase Dashboard → Authentication):
# - Enable Email provider for zID/password sign-in (z1234567 → @student.unsw.edu.au, z123456 → @ad.unsw.edu.au).
# - Enable Google for Alternative logins (Authentication → Sign In / Providers).
# - Redirect URLs: clickyunswstartup://** and your Expo dev URL from `npx expo start` (exp://...).

# --- Local Supabase (after `npm run supabase:start` OR `docker compose --profile supabase up -d`) ---
# Use 127.0.0.1 when Metro/Expo runs on your host machine.
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# Use host.docker.internal when Metro/Expo runs inside the `app` Docker service (this repo).
# EXPO_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
#
# Default local anon key (public demo key used by Supabase local stacks).
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
